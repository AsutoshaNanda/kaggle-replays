# =============================================================================
# Kaggle Replays — environment variable reference (example values only)
#
# IMPORTANT: this project has TWO env files, not one. This root file documents
# every variable in one place; copy the relevant section into:
#   - Backend:  Backend/backend/.env   (template: Backend/backend/.env.example)
#   - Frontend: Frontend/.env          (template: Frontend/.env.example)
#
# Never put real values here and never commit a real .env (see .gitignore).
#
# NOTE ON KAGGLE AUTH: this app does NOT use a Kaggle API key (kaggle.json /
# KAGGLE_USERNAME / KAGGLE_KEY). It logs in through a real browser session once
# (run `python login.py`, which saves the session to auth.json) and reuses that.
# =============================================================================

# ----------------------------------------------------------------------------
# Backend: Database
# Async SQLAlchemy URL using the aiomysql driver. Format:
#   mysql+aiomysql://USER:PASSWORD@HOST:3306/DBNAME
# ----------------------------------------------------------------------------
DATABASE_URL=mysql+aiomysql://kr_app:your_db_password@127.0.0.1:3306/kaggle_replays

# ----------------------------------------------------------------------------
# Backend: Auth / JWT
# Two DIFFERENT 64-hex-character secrets. Generate each with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------------------
JWT_SECRET=your_64_hex_char_access_token_secret
JWT_REFRESH_SECRET=your_64_hex_char_refresh_token_secret_must_differ

# ----------------------------------------------------------------------------
# Backend: CORS
# Comma-separated list of allowed origins (no wildcards). Frontend dev URL first.
# ----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173

# ----------------------------------------------------------------------------
# Backend: Local dev login
# When true, the frontend "Connect Kaggle Account" button logs in using the local
# auth.json created by `python login.py` (single-user local development only).
# Leave false/unset for any real or multi-user deployment.
# ----------------------------------------------------------------------------
DEV_LOGIN_ENABLED=false

# ----------------------------------------------------------------------------
# Backend: Filesystem locations
# Where per-user Kaggle sessions and downloaded replay output are written.
# ----------------------------------------------------------------------------
SESSIONS_BASE_DIR=./sessions
DOWNLOADS_BASE_DIR=./downloads

# ----------------------------------------------------------------------------
# Backend: Concurrency / lifecycle (optional — sensible defaults exist in code)
# ----------------------------------------------------------------------------
MAX_CONCURRENT_CONTEXTS=10
MAX_PARALLEL_DOWNLOAD_JOBS=5
JOB_OUTPUT_TTL_HOURS=0.25

# ----------------------------------------------------------------------------
# Backend: Logging (optional)
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/backend.log

# ----------------------------------------------------------------------------
# Frontend
# Base URL of the FastAPI backend (no trailing slash). Lives in Frontend/.env.
# ----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
