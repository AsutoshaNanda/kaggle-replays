# Copy to deploy/.env and fill in. Never commit the real .env.

# Your apex domain. The UI is served at https://DOMAIN and the API at https://api.DOMAIN
# (both DNS records must point at this server).
DOMAIN=yourdomain.com

# --- MySQL -------------------------------------------------------------------
MYSQL_DATABASE=kaggle_replays
MYSQL_USER=kr_app
MYSQL_PASSWORD=change_me_to_a_strong_password
MYSQL_ROOT_PASSWORD=change_me_to_a_strong_root_password

# --- JWT secrets -------------------------------------------------------------
# Two DIFFERENT 64-hex-char secrets. Generate each with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_64_hex_chars
JWT_REFRESH_SECRET=change_me_64_hex_chars_must_differ
