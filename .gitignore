# ============================================================================
# Secrets & live credentials — NEVER commit these.
# This project authenticates to Kaggle using a real, logged-in browser session
# (auth.json). Committing any of the below would leak your Kaggle account and/or
# the application's signing secrets.
# ============================================================================
**/auth.json
**/request.txt
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.*.local
**/.env.*
!**/.env.example
**/kaggle.json
.kaggle/
*.pem
*.key
*.p12

# ============================================================================
# Per-user runtime data (account-specific; not source)
# ============================================================================
**/sessions/
Backend/downloads/
**/logs/
# (was `**/downloads/` — that also hid Frontend/src/components/downloads/ source)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# Python
# ============================================================================
**/.venv/
**/venv/
env/
**/__pycache__/
*.py[cod]
*.egg
*.egg-info/
wheels/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ============================================================================
# Node / frontend
# ============================================================================
**/node_modules/
**/dist/
**/dist-ssr/
build/
.next/
.nuxt/
out/
**/.vite/
**/.tsnode/
*.tsbuildinfo

# ============================================================================
