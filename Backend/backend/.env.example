# =============================================================================
# Kaggle Replay Analytics — backend environment template
# Copy to backend/.env and fill in real values. NEVER commit the real .env.
# =============================================================================

# --- Database ----------------------------------------------------------------
# Async SQLAlchemy URL (aiomysql driver). The DB user needs SELECT/INSERT/UPDATE
# (and DELETE) on this schema for runtime; running `alembic upgrade head` also
# needs DDL (CREATE/ALTER/DROP/INDEX). Grant DDL to a migration user or to this
# user during setup, then it is unused at runtime.
DATABASE_URL=mysql+aiomysql://kr_app:CHANGE_ME@127.0.0.1:3306/kaggle_replays

# --- JWT secrets -------------------------------------------------------------
# Each must be at least 64 hex chars. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_64_HEX_CHARS
# Must DIFFER from JWT_SECRET. Generate the same way.
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_HEX_CHARS

# --- CORS --------------------------------------------------------------------
# Comma-separated allowed origins. No wildcards. Frontend dev server first.
ALLOWED_ORIGINS=http://localhost:5173

# --- Filesystem locations ----------------------------------------------------
# Per-user Playwright auth.json lives here; MUST be outside any static serve path.
SESSIONS_BASE_DIR=./sessions
# Job output (replay JSONs / ZIPs) is written here.
DOWNLOADS_BASE_DIR=./downloads

# --- Concurrency / lifecycle -------------------------------------------------
# Max cached Playwright contexts (LRU-evicted beyond this).
MAX_CONCURRENT_CONTEXTS=10
# Max simultaneously executing download jobs.
MAX_PARALLEL_DOWNLOAD_JOBS=5
# Hours before a finished job's output ZIP is auto-deleted (0.25 = 15 minutes).
JOB_OUTPUT_TTL_HOURS=0.25

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/backend.log
